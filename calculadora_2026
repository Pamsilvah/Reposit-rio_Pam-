def calcular(num1, operador, num2):
    if operador == "+":
        return num1 + num2 
    elif operador == "-":
        return num1 - num2 
    elif operador == "*":
        return num1 * num2
    elif operador == "/":
        if num2 != 0:
            return num1 / num2
        else: 
            return "erro: divisão por zero!"
    else: 
        return "operação inválida"

